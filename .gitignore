# Playwright artifacts (per-project, generated by playwright-cli)
.playwright-cli/

# Test screenshots — keep README screenshots inline in the doc folder if needed
*.png
*.jpg
*.jpeg
*.yml
*.yaml

# OS junk
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp

# Local Claude Code settings (tooling, not project code)
.claude/

# Local-dev loader stubs (each contains a file:// @require pointing at the
# real .user.js — useful for live-reload during development, not relevant
# to anyone installing the script from GitHub).
*.loader.user.js
